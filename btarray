        printf("1. Insert\n");
        printf("2. Delete\n");
        printf("3. Level Order Traversal\n");
        printf("4. Pre-Order Traversal\n");
        printf("5. In-Order Traversal\n");
        printf("6. Post-Order Traversal\n");
        printf("7. Exit\n");
        printf("Enter Choice: ");
